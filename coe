//GPS START
void GPS_Read()
{
    while (HAL_UART_Receive(&huart1, &gps_byte, 1, 1) == HAL_OK)
    {
        if (gps_byte == '\n')
        {
            gps_buffer[gps_index] = '\0';

            if (strncmp(gps_buffer, "$GNGLL,", 7) == 0 || strncmp(gps_buffer, "$GPGLL,", 7) == 0)
            {
                char *token;
                char temp[128];
                strncpy(temp, gps_buffer, sizeof(temp) - 1);
                temp[sizeof(temp) - 1] = '\0';

                token = strtok(temp, ","); // $GNGLL
                token = strtok(NULL, ","); // lat
                if (token) strncpy(gps_lat, token, sizeof(gps_lat) - 1);

                token = strtok(NULL, ","); // N/S
                token = strtok(NULL, ","); // lon
                if (token) strncpy(gps_lon, token, sizeof(gps_lon) - 1);
            }

            gps_index = 0;
        }
        else if (gps_byte != '\r')
        {
            if (gps_index < sizeof(gps_buffer) - 1)
                gps_buffer[gps_index++] = gps_byte;
            else
                gps_index = 0;
        }
    }
}
//GPS END
//BME TYPESHIFT
uint8_t BME280_ReadReg(uint8_t reg)
{
    uint8_t value;
    HAL_I2C_Mem_Read(&hi2c1, BME280_ADDR, reg, 1, &value, 1, 100);
    return value;
}
void BME280_Init()
{
    uint8_t data;

    data = 0x01;
    HAL_I2C_Mem_Write(&hi2c1, BME280_ADDR, 0xF2, 1, &data, 1, 100);

    data = 0x27;
    HAL_I2C_Mem_Write(&hi2c1, BME280_ADDR, 0xF4, 1, &data, 1, 100);

    data = 0xA0;
    HAL_I2C_Mem_Write(&hi2c1, BME280_ADDR, 0xF5, 1, &data, 1, 100);
}
void BME280_ReadRaw()
{
    HAL_I2C_Mem_Read(&hi2c1, BME280_ADDR, 0xF7, 1, buffer, 8, 100);

    press_raw = (buffer[0] << 12) | (buffer[1] << 4) | (buffer[2] >> 4);
    temp_raw  = (buffer[3] << 12) | (buffer[4] << 4) | (buffer[5] >> 4);
    hum_raw   = (buffer[6] << 8) | buffer[7];
}
void Print_BME280()
{
    char buf[64];
    sprintf(buf, "Traw:%ld Praw:%ld Hraw:%ld\r\n",
            temp_raw, press_raw, hum_raw);

    HAL_UART_Transmit(&huart2, (uint8_t*)buf, strlen(buf), HAL_MAX_DELAY);
}
//END OF BME TYPESHIFT

//Start of MPU typeshift
uint8_t MPU6050_ReadReg(uint8_t reg)
{
    uint8_t value;
    HAL_I2C_Mem_Read(&hi2c1, MPU6050_ADDR, reg, 1, &value, 1, 100);
    return value;
}

void MPU6050_WriteReg(uint8_t reg, uint8_t data)
{
    HAL_I2C_Mem_Write(&hi2c1, MPU6050_ADDR, reg, 1, &data, 1, 100);
}

void MPU6050_Init(void)
{
    // вывести из сна
    MPU6050_WriteReg(0x6B, 0x00);

    // гироскоп ±250 deg/s
    MPU6050_WriteReg(0x1B, 0x00);

    // акселерометр ±2g
    MPU6050_WriteReg(0x1C, 0x00);
}

void MPU6050_ReadRaw(void)
{
    uint8_t data[14];

    HAL_I2C_Mem_Read(&hi2c1, MPU6050_ADDR, 0x3B, 1, data, 14, 100);

    acc_x = (int16_t)(data[0] << 8 | data[1]);
    acc_y = (int16_t)(data[2] << 8 | data[3]);
    acc_z = (int16_t)(data[4] << 8 | data[5]);

    temp_mpu = (int16_t)(data[6] << 8 | data[7]);

    gyro_x = (int16_t)(data[8] << 8 | data[9]);
    gyro_y = (int16_t)(data[10] << 8 | data[11]);
    gyro_z = (int16_t)(data[12] << 8 | data[13]);
}

void Print_MPU6050()
{
    char buf[128];
    sprintf(buf,
        "MPU AX:%d AY:%d AZ:%d GX:%d GY:%d GZ:%d\r\n",
        acc_x, acc_y, acc_z, gyro_x, gyro_y, gyro_z);

    HAL_UART_Transmit(&huart2, (uint8_t*)buf, strlen(buf), HAL_MAX_DELAY);
}
//end of mpu typeshift
void Print_All()
{
    char buf[256];

    sprintf(buf,
        "%d;%d;%d;%d;%d;%d;%ld;%ld;%ld;%s;%s\r\n",
        acc_x, acc_y, acc_z,
        gyro_x, gyro_y, gyro_z,
        temp_raw, press_raw, hum_raw,
        gps_lat, gps_lon);

    HAL_UART_Transmit(&huart2, (uint8_t*)buf, strlen(buf), HAL_MAX_DELAY);
}
